#!/bin/bash

# Kill the session if it already exists so we always start fresh
tmux kill-session -t forge_swarm 2>/dev/null

# Define the common analysis prompt as a variable to keep the script clean
ANALYZE_PROMPT='Find the log file describing past AI agent activity (check file date to avoid looking at the log of your current interaction that is in the same folder). Use the Analyst to generate a summary of this interaction, which should include errors that were encountered and description of tasks that took long time to achieve or were stuck in loops. Read the summary from the Analyst and write your interpretation into a markdown formatted file. Then take the summary and append the code of the AI agent (/app/god_tools.py, /app/chat_overseer.py, and /app/config.py), send it to the Analyst and ask for suggestions for how to improve those Python scripts to avoid the issues. Do not try to just get a new code but rather detailed list of suggestions for improvements with explanations. If you need to, plan, forge new tools, run code, explore your environment, ask Adviser or use the Analyst to check your findings multiple times.'

# 1. Create a new detached tmux session named "forge_swarm"
tmux new-session -d -s forge_swarm

# 2. Pane 0 (Top-Left): Agent 1 in Text Mode
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_5' -p 'I want you to find a homologue of TssB protein of Vibrio cholerae in Pseudomonas aeruginosa PAO1. Write a plan how to achieve this and ask the Adviser for ideas. Report protein alignment and write the outcome of your analysis to a markdown formatted file. Describe what was difficult about this and what tools would help to get to the answer quickly.'; echo -e '\n--- TEST COMPLETE, STARTING ANALYSIS ---' ; pixi run python chat_overseer.py -x -f formatted -s 'Agent_5' -p '${ANALYZE_PROMPT}'" C-m

# 3. Pane 1 (Top-Right): Agent 2 in Text Mode
tmux split-window -h -t forge_swarm
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_6' -p 'I want to delete from Vibrio cholerae V52 genome the gene that encodes TssB protein. Ask adviser for ideas and search web for most accurate instructions. Provide links to manuscripts. Write a detailed laboratory protocol for achieving the objective. Include ideas for troubleshooting.'; echo -e '\n--- TEST COMPLETE, STARTING ANALYSIS ---' ; pixi run python chat_overseer.py -x -f formatted -s 'Agent_6' -p '${ANALYZE_PROMPT}'" C-m

# 4. Pane 2 (Bottom-Left): Agent 3 in MD Mode (Splits the top-left pane)
tmux split-window -v -t forge_swarm:0.0
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_7' -p 'In the input folder, you find a folder with 5 PDFs. I want you to summarize each PDF, write a detailed summary of what you found. Generate a CSV table with the following data: Name, Age, Nationality, Field of study, Summary of Master Project, Biology Grade (if available).'; echo -e '\n--- TEST COMPLETE, STARTING ANALYSIS ---' ; pixi run python chat_overseer.py -x -f formatted -s 'Agent_7' -p '${ANALYZE_PROMPT}'" C-m

# 5. Pane 3 (Bottom-Right): Agent 4 in MD Mode (Splits the top-right pane)
tmux split-window -v -t forge_swarm:0.2
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_8' -p 'In the input folder, you find a folder with 3 images. I want you to describe each of them. Make a plan to how to identify objects on the images. Ask Adviser for ideas. Execute the plan.'; echo -e '\n--- TEST COMPLETE, STARTING ANALYSIS ---' ; pixi run python chat_overseer.py -x -f formatted -s 'Agent_8' -p '${ANALYZE_PROMPT}'" C-m

# 6. Balance the panes into a perfect 2x2 grid
tmux select-layout -t forge_swarm tiled

# 7. Attach to watch your swarm wake up!
tmux attach-session -t forge_swarm
